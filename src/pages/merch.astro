---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import { creator, getProjectsByCategory } from "../content/projects";
import { mediumPages } from "../content/pages";

const page = mediumPages.merch;
const items = page.categories.flatMap((category) => getProjectsByCategory(category));
---

<BaseLayout title={`Merch | ${creator.name}`} description={page.description}>
  <main>
    <PageHeader eyebrow={page.eyebrow} title={page.title} description={page.description} />
    <section class="section first-section">
      <ProjectGrid projects={items} />
      {
        items.length === 0 && (
          <div class="empty-panel">
            <h2>Objects are forming.</h2>
            <p>Symbols, slogans, covers, signed editions, apparel, prints, bundles, and other objects from the archive gather here.</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
