---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { creator } from "../content/projects";
---

<BaseLayout title={`Contact | ${creator.name}`} description="Contact links and platform links.">
  <main>
    <PageHeader
      eyebrow="Contact"
      title="Collaborations, questions, licensing, and correspondence."
      description="Use the links below to follow the work, ask about a project, or start a conversation."
    />
    <section class="section first-section">
      <div class="contact-grid">
        {
          creator.socialLinks.map((link) => (
            <a href={link.url}>
              <strong>{link.label}</strong>
              <span>{link.url.replace("mailto:", "")}</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
