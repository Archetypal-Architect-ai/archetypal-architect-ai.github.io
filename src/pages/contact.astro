---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { creator } from "../content/projects";
---

<BaseLayout title={`Contact | ${creator.name}`} description="Contact links and platform links.">
  <main>
    <PageHeader
      eyebrow="Contact"
      title="For collaborations, licensing, questions, or wandering through the work."
      description="Simple links for now. No form, no backend, no extra machinery."
    />
    <section class="section first-section">
      <div class="contact-grid">
        {
          creator.socialLinks.map((link) => (
            <a href={link.url}>
              <strong>{link.label}</strong>
              <span>{link.url.replace("mailto:", "")}</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
