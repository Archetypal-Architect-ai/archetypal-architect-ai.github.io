---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { creator } from "../../content/projects";
---

<BaseLayout title={`Projects | ${creator.name}`} description="The project archive lives as a cross-linked wiki.">
  <main>
    <PageHeader
      eyebrow="Projects"
      title="Projects Live in the Wiki"
      description="The archive treats each project as part of a larger network of stories, songs, images, systems, and symbols."
    />
    <section class="section first-section prose-section">
      <p><a class="button primary" href="/wiki">Open the Wiki</a></p>
    </section>
  </main>
</BaseLayout>
