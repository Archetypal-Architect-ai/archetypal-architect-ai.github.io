---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { creator } from "../../content/projects";
---

<BaseLayout title={`Projects moved to Wiki | ${creator.name}`} description="The project archive now lives as a cross-linked wiki.">
  <main>
    <PageHeader
      eyebrow="Moved"
      title="Projects are now Wiki Entries"
      description="The archive works better as a web of connected stories, songs, images, atlas nodes, and merch threads."
    />
    <section class="section first-section prose-section">
      <p><a class="button primary" href="/wiki">Open the Wiki</a></p>
    </section>
  </main>
</BaseLayout>
