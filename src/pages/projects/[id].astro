---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { projects, creator } from "../../content/projects";

export function getStaticPaths() {
  return projects.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
---

<BaseLayout title={`${entry.title} moved to Wiki | ${creator.name}`} description={entry.summary}>
  <main>
    <PageHeader
      eyebrow="Moved"
      title={entry.title}
      description="This entry now lives in the creator wiki, where its connections and backlinks are visible."
    />
    <section class="section first-section prose-section">
      <p><a class="button primary" href={`/wiki/${entry.id}`}>Open Wiki Entry</a></p>
    </section>
  </main>
</BaseLayout>
