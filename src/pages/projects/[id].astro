---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { publicProjects, creator } from "../../content/projects";

export function getStaticPaths() {
  return publicProjects.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
---

<BaseLayout title={`${entry.title} | ${creator.name}`} description={entry.summary}>
  <main>
    <PageHeader
      eyebrow="Project"
      title={entry.title}
      description="This project belongs to the larger archive, where its themes, influences, and related works can be followed."
    />
    <section class="section first-section prose-section">
      <p><a class="button primary" href={`/wiki/${entry.id}`}>Open Wiki Entry</a></p>
    </section>
  </main>
</BaseLayout>
