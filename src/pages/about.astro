---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { creator } from "../content/projects";
---

<BaseLayout title={`About | ${creator.name}`} description={creator.bio}>
  <main>
    <PageHeader eyebrow="Creator" title="About" description={creator.bio} />
    <section class="section prose-section first-section">
      <h2>The Work</h2>
      <p>{creator.aboutTheWork}</p>
      <p>
        The archive gathers books, songs, essays, videos, tools, images, and objects as parts of one larger conversation.
        Each entry can point toward the others because the work rarely stays inside one medium for long.
      </p>
    </section>
  </main>
</BaseLayout>
