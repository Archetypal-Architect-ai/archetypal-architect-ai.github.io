---
import BaseLayout from "../layouts/BaseLayout.astro";

const kitDestination = "https://archetypal-architect.kit.com";
const title = "Rowan's Honey Cakes | Archetypal Architect";
const description =
  "Join the Archetypal Architect reader table and get Rowan's third-batch honey cake recipe from The Gentle Shadow.";
---

<BaseLayout title={title} description={description} image="/images/works/the-gentle-shadow-cover.jpg">
  <main>
    <section class="detail-hero">
      <div>
        <p class="eyebrow">Reader Bonus / The Gentle Shadow</p>
        <h1>Want Rowan's Honey Cakes?</h1>
        <p>
          Thank you so much for reading my story. I have so much more to tell, and I'd love
          to have you beside me for the next journey.
        </p>
        <p>
          There will be honey cakes, scarves aplenty, and probably someone who needs both.
          In fact, the first batch is ready now: join me at the table, and I'll send you my
          third-batch honey cake recipe.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={kitDestination}>Send me the recipe</a>
          <a class="button secondary" href="/rowans-honey-cakes">Read the recipe page</a>
          <a class="button secondary" href="/wiki/the-gentle-shadow">Open the book page</a>
        </div>
      </div>
      <img src="/images/works/the-gentle-shadow-cover.jpg" alt="Cover art for The Gentle Shadow." />
    </section>

    <section class="section first-section prose-section">
      <p class="eyebrow">Permanent Reader Link</p>
      <h2>The Table Stays Here</h2>
      <p>
        Books travel farther than mailing-list buttons. This address stays on the back page
        like a lantern in the window, even when the machinery behind the invitation changes.
      </p>
      <p>
        If the button does not open, visit <a href={kitDestination}>{kitDestination}</a>.
      </p>
    </section>
  </main>
</BaseLayout>
