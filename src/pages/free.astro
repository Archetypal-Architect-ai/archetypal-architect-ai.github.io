---
const destination = "https://archetypal-architect.kit.com/profile";
const title = "Free Reader List | Archetypal Architect";
const description =
  "Redirecting to the Archetypal Architect reader list on Kit.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${destination}`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="canonical" href={destination} />
    <style>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      body {
        align-items: center;
        background: #0f1112;
        color: #f4efe6;
        display: grid;
        margin: 0;
        min-height: 100vh;
        padding: 24px;
        text-align: center;
      }

      main {
        display: grid;
        gap: 18px;
        justify-items: center;
      }

      a {
        border: 1px solid rgba(244, 239, 230, 0.22);
        color: #f7c477;
        font-weight: 850;
        padding: 12px 18px;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Redirecting to the reader list.</h1>
      <p>If the page does not move on its own, use the link below.</p>
      <a href={destination}>Open Archetypal Architect on Kit</a>
    </main>
    <script is:inline define:vars={{ destination }}>
      window.location.replace(destination);
    </script>
  </body>
</html>
