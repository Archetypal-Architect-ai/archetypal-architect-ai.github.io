---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import TagList from "../components/TagList.astro";
import { adultProjects, creator, displayStatus } from "../content/projects";
---

<BaseLayout
  title={`Adult Archive | ${creator.name}`}
  description="Age-gated index for adult-genre fiction and mature symbolic material."
>
  <main>
    <PageHeader
      eyebrow="Adult Archive"
      title="Mature Stories, Separate Shelf"
      description="Some parts of the mythos speak through adult desire, erotic genre logic, body transformation, power, and taboo. They belong in their own wing."
    />

    <section class="section adult-gate" data-adult-gate>
      <div>
        <p class="eyebrow">Content Notice</p>
        <h2>Adult material ahead.</h2>
        <p>
          The entries beyond this point discuss erotica, adult themes, desire, transformation,
          and mature genre premises. Continue only if that is what you came looking for.
        </p>
        <button class="button primary" type="button" data-confirm-adult>I am 18+ and want to continue</button>
        <a class="button secondary" href="/wiki">Return to Public Wiki</a>
      </div>
    </section>

    <section class="section adult-archive is-locked" data-adult-content>
      <div class="section-heading">
        <p class="eyebrow">Separated Shelf</p>
        <h2>Series Hubs and References</h2>
        <p>These series explore the mythos through adult genre language.</p>
      </div>
      <div class="project-grid adult-grid">
        {
          adultProjects.map((project) => (
            <article class:list={["project-card", project.entryRole?.toLowerCase(), "adult-card"]}>
              <a class="thumb-link" href={`/adult/${project.id}`} aria-label={`Open ${project.title}`}>
                <img src={project.thumbnail} alt={project.thumbnailAlt} loading="lazy" />
              </a>
              <div class="project-card-body">
                <div class="card-meta">
                  {project.entryRole && <span class="role-pill">{project.entryRole}</span>}
                  <span>{project.kind}</span>
                  <span>{displayStatus(project.status)}</span>
                </div>
                <h2><a href={`/adult/${project.id}`}>{project.title}</a></h2>
                <p>{project.summary}</p>
                <TagList tags={project.tags.slice(0, 3)} />
                <div class="external-links text">
                  <a href={`/adult/${project.id}`}><span>Open adult entry</span><span aria-hidden="true">-&gt;</span></a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline>
    const gate = document.querySelector("[data-adult-gate]");
    const content = document.querySelector("[data-adult-content]");
    const button = document.querySelector("[data-confirm-adult]");
    const key = "aa-adult-archive-confirmed";

    function hasConsent() {
      try { if (window.localStorage.getItem(key) === "yes") return true; } catch {}
      try { if (window.sessionStorage.getItem(key) === "yes") return true; } catch {}
      return document.cookie.split("; ").some((item) => item === `${key}=yes`);
    }

    function saveConsent() {
      try { window.localStorage.setItem(key, "yes"); } catch {}
      try { window.sessionStorage.setItem(key, "yes"); } catch {}
      try { document.cookie = `${key}=yes; path=/; max-age=2592000; SameSite=Lax`; } catch {}
    }

    function unlock() {
      gate?.classList.add("is-hidden");
      content?.classList.remove("is-locked");
      content?.querySelectorAll('a[href^="/adult/"]').forEach((link) => {
        const url = new URL(link.href, window.location.origin);
        url.searchParams.set("adult", "yes");
        link.href = url.pathname + url.search;
      });
    }

    if (hasConsent()) unlock();
    button?.addEventListener("click", () => {
      saveConsent();
      unlock();
    });
  </script>
</BaseLayout>
