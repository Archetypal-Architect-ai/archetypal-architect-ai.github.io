---
import { publicProjects } from "../content/projects";
---

<section class="section wiki-map-section">
  <div class="section-heading">
    <p class="eyebrow">Labyrinth Map</p>
    <h2>How Things Feed Each Other</h2>
    <p>The map traces the maze: songs born from novels, systems becoming gods, species leading to civilizations, and symbols crossing from one world into another.</p>
  </div>
  <div class="wiki-map">
    {
      publicProjects
        .filter((entry) => entry.connections?.length)
        .map((entry) => (
          <article>
            <a class="map-node" href={`/wiki/${entry.id}`}>
              <span>{entry.kind}</span>
              <strong>{entry.title}</strong>
            </a>
            <div class="map-links">
              {entry.connections!.map((connection) => {
                const target = publicProjects.find((item) => item.id === connection.id);
                return (
                  target && (
                    <a href={`/wiki/${target.id}`}>
                      <small>{connection.type}</small>
                      <span>{target.title}</span>
                    </a>
                  )
                );
              })}
            </div>
          </article>
        ))
    }
  </div>
</section>
