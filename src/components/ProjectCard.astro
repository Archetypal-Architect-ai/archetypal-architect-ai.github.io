---
import ExternalLinks from "./ExternalLinks.astro";
import TagList from "./TagList.astro";
import { displayStatus, type Project } from "../content/projects";

const { project } = Astro.props as { project: Project };
const visibleTags = project.tags.slice(0, 3);
const hiddenTagCount = Math.max(project.tags.length - visibleTags.length, 0);
---

<article class:list={["project-card", project.entryRole?.toLowerCase()]}>
  <a class="thumb-link" href={`/wiki/${project.id}`} aria-label={`Open ${project.title}`}>
    <img src={project.thumbnail} alt={project.thumbnailAlt} loading="lazy" />
  </a>
  <div class="project-card-body">
    <div class="card-meta">
      {project.entryRole && <span class="role-pill">{project.entryRole}</span>}
      <span>{project.kind}</span>
      <span>{displayStatus(project.status)}</span>
    </div>
    <h2><a href={`/wiki/${project.id}`}>{project.title}</a></h2>
    <p>{project.summary}</p>
    {
      project.connections?.length ? (
        <p class="micro-note">{project.connections.length} linked entries</p>
      ) : null
    }
    <TagList tags={visibleTags} />
    {hiddenTagCount ? <p class="micro-note">+{hiddenTagCount} more tags</p> : null}
    <ExternalLinks links={[{ label: "Open entry", url: `/wiki/${project.id}`, type: "Reference" }]} />
  </div>
</article>
